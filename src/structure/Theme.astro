---
---

<style is:global>
@import url(https://db.onlinewebfonts.com/c/a784b1ecdd0ee70357252c6a5318b86c?family=Orgon+W03+Regular);
@import url(https://db.onlinewebfonts.com/c/ede5905d909313904bc26c008669b3c1?family=Orgon+W03+Medium);
@import url(https://db.onlinewebfonts.com/c/52a702b9dab6b09b15ae6c23ecb1835e?family=Orgon+W03+Black);

    :root {
        --color-coffee-off-white: #FFFCF5;
        --color-coffee-tan: #C9A58B;
        --color-coffee-brown: #AC744C;
        --color-coffee-white: #ffffff;
        --color-coffee-dark-grey-opacity: #222120e6;
        --color-coffee-dark-grey: #222120;

        --font-family-orgon-regular: 'Orgon W03 Regular', sans-serif;
        --font-family-orgon-medium: 'Orgon W03 Medium', sans-serif;
        --font-family-orgon-black: 'Orgon W03 Black', sans-serif;
    }

    body {
        box-sizing: border-box;
        font-family: var(--font-family-orgon-regular), sans-serif;
        background-color: var(--color-coffee-off-white);
        color: var(--color-coffee-dark-grey);
        margin: 0;
        padding: 0;
    }

    h1, h2, h3 {
        font-family: var(--font-family-orgon-black), sans-serif;
        color: var(--color-coffee-brown);
    }

    a {
        font-family: var(--font-family-orgon-medium), sans-serif;
        color: var(--color-coffee-brown);
        text-decoration: underline;
    }

    a:hover {
        text-decoration: underline 3px;
    }


</style>